{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb"
      }
    },
    {
      "src": "schedule_agent_web/static/**",
      "use": "@vercel/static"
    }
  ],
  "installCommand": "pip install -r requirements-vercel.txt",
  "routes": [
    { "src": "/assets/(.*)", "dest": "schedule_agent_web/static/assets/$1" },
    { "src": "/api/(.*)", "dest": "api/index.py" },
    { "src": "/(.*)", "dest": "api/index.py" }
  ]
}
